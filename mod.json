{
	"geode": "5.7.1",
	"version": "v2.1.1",
	"gd": {
		"win": "2.2081",
		"mac": "2.2081"
	},
	"id": "toastexgd.toastyreplay",
	"name": "ToastyReplay",
	"developer": "ToastexGD",
	"description": "Frame-perfect replay bot for Geode.",
	"links": {
		"source": "https://github.com/ToastexGD/ToastyReplay"
	},
	"dependencies": {
		"eclipse.ffmpeg-api": {
			"version": ">=v2.0.0",
			"required": false
		}
	},
	"incompatibilities": {
		"toastexgd.toastyreplay-pro": {
			"version": "*",
			"breaking": true
		}
	},
	"settings": {
		"ui_language": {
			"name": "UI Language",
			"type": "string",
			"default": "Auto",
			"one-of": [
				"Auto",
				"English",
				"Espanol",
				"Francais",
				"TiengViet",
				"Zhongwen"
			]
		},
		"ffmpeg_path": {
			"name": "ffmpeg.exe Path",
			"type": "file",
			"default": ""
		},
		"render_folder": {
			"name": "Render Save Location",
			"type": "folder",
			"default": ""
		}
	},
	"resources": {
		"files": ["resources/*.ttf", "resources/*.png", "resources/lang/*.json", "resources/*.txt"]
	},
	"tags": ["gameplay", "utility", "cheat"]
}
